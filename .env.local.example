# Copy this file to .env.local and fill in the values.

# ── Resend (email) ──────────────────────────────────────────
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=

# Verified sender address. During testing: onboarding@resend.dev
# In production, verify your domain at resend.com/domains
RESEND_FROM_EMAIL=onboarding@resend.dev

# Your public site URL (used in email links)
NEXT_PUBLIC_SITE_URL=https://yoursite.com

# ── Vercel KV (Redis) — for persistent storage ──────────────
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
KV_URL=

# ── Vercel Blob — for uploaded images and PDFs ──────────────
BLOB_READ_WRITE_TOKEN=
