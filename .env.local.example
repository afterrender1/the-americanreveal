# Copy this file to .env.local and fill in the values from Vercel dashboard.
# Local development works WITHOUT these — they are only needed in production.

# Vercel KV (Redis) — for persistent article and subscriber storage
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
KV_URL=

# Vercel Blob — for uploaded images and PDFs
BLOB_READ_WRITE_TOKEN=
